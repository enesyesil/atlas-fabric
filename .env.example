# Model selection — change provider/model without touching code
GENERATOR_MODEL=anthropic/claude-opus-4-5
REVIEWER_MODEL=anthropic/claude-opus-4-5

# Provider API keys — only set the ones you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Azure AI Foundry (official LangChain integration; use deployment names, not catalog names)
# GENERATOR_MODEL=azure/kimi-prod
# REVIEWER_MODEL=azure/kimi-prod
# AZURE_API_BASE=https://<resource>.services.ai.azure.com/openai/v1
AZURE_API_BASE=
AZURE_API_KEY=

# Temperatures
GENERATOR_TEMPERATURE=0.2
REVIEWER_TEMPERATURE=0.0

# Infrastructure
# If using the Docker container: docker compose up -d mongo
MONGODB_URI=mongodb://localhost:27017
API_SECRET_KEY=

# Server
PORT=8080

# Data
NATURAL_EARTH_DATA_PATH=./data/ne_10m_admin_1_states_provinces.geojson

# Tracing — off by default, uses existing MONGODB_URI
TRACING_ENABLED=false
